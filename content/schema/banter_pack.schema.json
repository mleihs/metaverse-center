{
  "$defs": {
    "BanterItem": {
      "additionalProperties": false,
      "description": "One between-encounter banter template.\n\n`personality_filter` is intentionally a loose dict: values can be\n`[min, max]` tuples for a Big-Five dimension (e.g.\n`neuroticism: [0.6, 1.0]`) OR `True`/`False` flags for non-trait\nmatchers like `opinion_positive_pair`. Runtime filter logic in\n`dungeon_banter.select_banter` dispatches on the value type.",
      "properties": {
        "attachment_tier": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Attachment Tier"
        },
        "awareness_tier": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Awareness Tier"
        },
        "decay_tier": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Decay Tier"
        },
        "fracture_tier": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Fracture Tier"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "insight_tier": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Insight Tier"
        },
        "personality_filter": {
          "additionalProperties": {
            "anyOf": [
              {
                "items": {
                  "type": "number"
                },
                "type": "array"
              },
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ]
          },
          "title": "Personality Filter",
          "type": "object"
        },
        "text_de": {
          "title": "Text De",
          "type": "string"
        },
        "text_en": {
          "title": "Text En",
          "type": "string"
        },
        "trigger": {
          "title": "Trigger",
          "type": "string"
        },
        "water_tier": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Water Tier"
        }
      },
      "required": [
        "id",
        "trigger",
        "text_en",
        "text_de"
      ],
      "title": "BanterItem",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "banter": {
      "items": {
        "$ref": "#/$defs/BanterItem"
      },
      "title": "Banter",
      "type": "array"
    },
    "schema_version": {
      "default": 1,
      "title": "Schema Version",
      "type": "integer"
    }
  },
  "required": [
    "banter"
  ],
  "title": "BanterPack",
  "type": "object"
}
