# Velgarien Production Environment Variables
# Copy to .env or set as environment variables in your deployment platform (e.g. Railway)

# === Supabase (Required) ===
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-key-from-supabase-dashboard>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key-from-supabase-dashboard>
SUPABASE_JWT_SECRET=<jwt-secret-from-supabase-dashboard>

# === Frontend (Vite build-time variables) ===
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<same-anon-key>

# === Backend ===
ENVIRONMENT=production
CORS_ORIGINS=https://your-frontend-domain.com
PLATFORM_ADMIN_EMAILS=matthias@leihs.at

# === AI Services (Optional) ===
OPENROUTER_API_KEY=<openrouter-api-key>

# === External APIs (Optional) ===
GUARDIAN_API_KEY=<guardian-api-key>
NEWSAPI_KEY=<newsapi-key>
FACEBOOK_ACCESS_TOKEN=<facebook-access-token>

# === Analytics (Optional) ===
VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# === Sentry (Optional) ===
SENTRY_DSN=<sentry-dsn-from-project-settings>
VITE_SENTRY_DSN=<same-sentry-dsn-for-frontend>
# Release tracking (Railway: uses git SHA automatically)
SENTRY_RELEASE=${{RAILWAY_GIT_COMMIT_SHA}}
# Source map upload (Railway build variables — only needed during Docker build)
SENTRY_AUTH_TOKEN=<sentry-internal-integration-token>
SENTRY_ORG=<sentry-org-slug>
SENTRY_PROJECT=<sentry-project-slug>

# === Image Generation (Optional) ===
REPLICATE_API_TOKEN=<replicate-api-token>
